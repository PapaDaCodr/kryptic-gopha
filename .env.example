# ─── Watchlist ────────────────────────────────────────────────────────────────
# Comma-separated Binance USDT-M Futures symbols
WATCHLIST=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT

# ─── Strategy Parameters ──────────────────────────────────────────────────────
SHORT_PERIOD=12
LONG_PERIOD=26
RSI_PERIOD=14
BAR_INTERVAL_SECONDS=60

# ─── Risk Management ──────────────────────────────────────────────────────────
TP=0.005               # Take-profit as a fraction (0.005 = 0.5%)
SL=0.003               # Stop-loss as a fraction   (0.003 = 0.3%)
INITIAL_BALANCE=10000.0
RISK_PER_TRADE=0.01    # Fraction of balance to risk per trade (0.01 = 1%)
DAILY_LOSS_LIMIT=0.05  # Circuit-breaker daily loss limit (0.05 = 5%)
MAX_OPEN_TRADES=5
TRAILING_SL=true
TRAILING_SL_PCT=0.003

# ─── Trading Mode ─────────────────────────────────────────────────────────────
# "paper" → simulation only (no real orders)
# "live"  → real orders on Binance Futures (requires API keys below)
TRADING_MODE=paper

# ─── Binance Testnet ──────────────────────────────────────────────────────────
# Set to "true" to use Binance Futures Testnet (https://testnet.binancefuture.com)
# Create testnet API keys at: https://testnet.binancefuture.com
# TRADING_MODE must be "live" to use testnet keys.
BINANCE_TESTNET=false

# ─── Binance API Credentials ──────────────────────────────────────────────────
# Required only when TRADING_MODE=live
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ─── Telegram Notifications (optional) ───────────────────────────────────────
# Create a bot via @BotFather, then start a chat and get the chat ID.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
ENV=dev   # "dev" enables human-readable console logs; omit for JSON logs
